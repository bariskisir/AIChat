{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Chat",
  "version": "1.10.3",
  "identifier": "com.bariskisir.AIChat",
  "build": {
    "frontendDist": "frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "AI Chat",
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
